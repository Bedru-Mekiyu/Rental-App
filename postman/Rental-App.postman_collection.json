        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const data = body && body.data ? body.data : {};",
                  "  if (data.token) pm.environment.set(\"accessToken\", data.token);",
                  "  if (data.refreshToken) pm.environment.set(\"refreshToken\", data.refreshToken);",
                  "  if (data.user && data.user.id) pm.environment.set(\"authUserId\", data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create Tenant User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Tenant One\",\n  \"email\": \"tenant.one@example.com\",\n  \"phone\": \"+251911000001\",\n  \"password\": \"Tenant123!\",\n  \"role\": \"TENANT\"\n}"
            },
            "url": "{{baseUrl}}/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  const data = body && body.data ? body.data : {};",
                  "  if (data.id) {",
                  "    pm.environment.set(\"createdUserId\", data.id);",
                  "    if (data.role === \"TENANT\") pm.environment.set(\"tenantId\", data.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
